---
import Navigation from "../components/Navigation.astro";
import Billboard from "../components/Billboard.astro";
import "../styles/global.css";
import "../styles/background.css";
import "../styles/fonts.css";

const { title, noBox = false } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/photos/A.png"/>
        <meta name="generator" content={Astro.generator} />
        <title>{title || "AQLYSR"}</title>
    </head>
    <body>
        <div id="snow"></div>
        <div class="menu-overlay"></div>
        <div class="container">
            <header class="">
                <div class="header-images">
                    <img src={import.meta.env.BASE_URL + "photos/A.webp"} alt="">
                    <img src={import.meta.env.BASE_URL + "photos/Q.webp"} alt="">
                    <img src={import.meta.env.BASE_URL + "photos/L.webp"} alt="">
                    <img src={import.meta.env.BASE_URL + "photos/Y.webp"} alt="">
                    <img src={import.meta.env.BASE_URL + "photos/S.webp"} alt="">
                    <img src={import.meta.env.BASE_URL + "photos/R.webp"} alt="">
                </div>
                <button id="menu-toggle" class="menu-toggle" aria-label="Toggle Menu">
                    <span class="bar"></span>
                    <span class="bar"></span>
                    <span class="bar"></span>
                </button>
            </header>


            <div class="content-wrapper">
                {
                    noBox ? (
                        <main class="main-content no-box">
                            <slot />
                        </main>
                    ) : (
                        <main class="box main-content">
                            <slot />
                        </main>
                    )
                }

                <aside class="sidebar">
                    <button id="menu-close" class="menu-close" aria-label="Close Menu">
                        &larr; Back
                    </button>
                    <Navigation />
                    <div class="box">
                        <h3>Contact and Social Media</h3>
                        <ul>
                            <li>
                                <a
                                    href="https://twitter.com/AQLYSR"
                                    target="_blank"
                                    rel="noopener noreferrer">Twitter</a
                                >
                            </li>
                            <li>
                                <a href="mailto:hello@aqilyusri.com">Email</a>
                            </li>
                            <li>
                                <a
                                    href="https://github.com/AQLYSR"
                                    target="_blank"
                                    rel="noopener noreferrer">GitHub</a
                                >
                            </li>
                            <li>
                                <a href={`${import.meta.env.BASE_URL}article/linkedin`}}>LinkedIn</a>
                            </li>
                        </ul>
                    </div>
                </aside>
            </div>

            <footer class="footer">
                <span>You have reached the end <br /> &#169; 2026 AQLYSR</span>
            </footer>
        </div>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const toggle = document.getElementById("menu-toggle");
                const sidebar = document.querySelector(".sidebar");
                const overlay = document.querySelector(".menu-overlay");
                const closeBtn = document.getElementById("menu-close");

                const toggleMenu = () => {
                    sidebar?.classList.toggle("active");
                    toggle?.classList.toggle("active");
                    overlay?.classList.toggle("active");
                };

                if (toggle && sidebar && overlay) {
                    toggle.addEventListener("click", toggleMenu);
                    overlay.addEventListener("click", toggleMenu);
                }

                if (closeBtn) {
                    closeBtn.addEventListener("click", toggleMenu);
                }

                const snowContainer = document.getElementById("snow");
                const snowCount = 200;

                if (snowContainer) {
                    for (let i = 0; i < snowCount; i++) {
                        const flake = document.createElement("div");
                        flake.classList.add("snowflake");
                        flake.textContent = "▪";

                        flake.style.left = Math.random() * 100 + "vw";
                        flake.style.fontSize = 4 + Math.random() * 6 + "px";
                        flake.style.animationDuration = 2 + Math.random() * 10 + "s";
                        flake.style.animationDelay = Math.random() * 10 + "s";
                        flake.style.opacity = 0.35 + Math.random() * 0.65;

                        snowContainer.appendChild(flake);
                    }
                }
            });
        </script>
    </body>
</html>

<style
    define:vars={{
        bgEnd: `url("${import.meta.env.BASE_URL}end.webp")`,
        bgTile: `url("${import.meta.env.BASE_URL}tile.webp")`,
    }}
>
    body {
        background-image: var(--bgEnd), var(--bgTile);
        background-repeat: no-repeat, repeat-y;
        background-position:
            center bottom,
            center top;
        background-size:
            100% auto,
            100% auto;
    }

    .header-images {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 20px;
        margin-bottom: 10px;
    }
    .header-images img {
        height: 50px;
        width: auto;
        display: block;
        image-rendering: pixelated;
    }

    .menu-toggle {
        display: none;
        position: absolute;
        top: 20px;
        right: 20px;
        flex-direction: column;
        justify-content: space-between;
        width: 30px;
        height: 21px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 1100;
        padding: 0;
    }

    .bar {
        height: 3px;
        width: 100%;
        background-color: #a9c1e8;
        border-radius: 10px;
        transition: 0.3s;
    }

    .menu-close {
        display: none;
    }

    @media (max-width: 768px) {
        .menu-toggle {
            display: flex;
        }

        .menu-toggle.active .bar:nth-child(1) {
            transform: translateY(9px) rotate(45deg);
        }

        .menu-toggle.active .bar:nth-child(2) {
            opacity: 0;
        }

        .menu-toggle.active .bar:nth-child(3) {
            transform: translateY(-9px) rotate(-45deg);
        }

        .sidebar {
            position: fixed;
            top: 0;
            right: 0;
            height: 100vh;
            width: 280px;
            background-color: #1a2634;
            border-left: 1px solid #a9c1e8;
            padding: 80px 20px 20px;
            transform: translateX(100%);
            transition: transform 0.3s ease-in-out;
            z-index: 1000;
            overflow-y: auto;
            box-shadow: -5px 0 15px rgba(0, 0, 0, 0.5);
        }

        .sidebar.active {
            transform: translateX(0);
        }

        .menu-overlay {
            position: fixed;
            inset: 0;
            background-color: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            z-index: 900;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease-in-out;
        }

        .menu-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .menu-close {
            display: flex;
            background: none;
            border: 1px solid #a9c1e8;
            color: #a9c1e8;
            padding: 5px 10px;
            margin-bottom: 20px;
            cursor: pointer;
            font-family: inherit;
            align-items: center;
            gap: 5px;
        }

        .menu-close:hover {
            background-color: #a9c1e8;
            color: #000;
        }
    }
</style>
